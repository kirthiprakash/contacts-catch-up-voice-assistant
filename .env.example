export VAPI_API_KEY=          # Secret API key — server-side only, never expose to browser
export VAPI_PUBLIC_KEY=       # Public key — safe for browser; Vapi dashboard → Account → API Keys
export VAPI_ASSISTANT_ID=
export VAPI_PHONE_NUMBER_ID=
export VAPI_SIP_TRUNK_ID=

export QDRANT_API_KEY=
export QDRANT_ENDPOINT=       # e.g. https://xxx.us-east-1-0.aws.cloud.qdrant.io:6333

export OPENAI_API_KEY=
export OPENAI_BASE_URL=       # e.g. https://api.openai.com/v1
export OPENAI_MODEL=          # e.g. gpt-4o

export APP_BASE=              # Public base URL — ngrok (local) or Railway URL (deployed)
                              # e.g. https://xyz.ngrok-free.dev  or  https://xxx.up.railway.app
export USER_NAME=             # Your name — used in call prompts e.g. Kirthi

export DATABASE_URL=          # Optional — defaults to contacts.db (local)
                              # Set to /data/contacts.db on Railway for persistent storage
