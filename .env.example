export VAPI_API_KEY=          # Secret API key — server-side only, never expose to browser
export VAPI_PUBLIC_KEY=       # Public key — safe for browser; Vapi dashboard → Account → API Keys
export VAPI_ASSISTANT_ID=
export VAPI_PHONE_NUMBER_ID=
export VAPI_SIP_TRUNK_ID=

export QDRANT_API_KEY=
export QDRANT_ENDPOINT=

# Embedding — set BASE_URL to a Gemini URL to use the native Gemini API;
# any other URL uses the OpenAI-compatible /embeddings endpoint.
# Gemini example (native API, auto-detected):
#   EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/  (any Gemini URL works)
#   EMBEDDING_MODEL=gemini-embedding-001
#   EMBEDDING_VECTOR_SIZE=3072
# nomic / Ollama example (OpenAI-compat):
#   EMBEDDING_BASE_URL=http://localhost:11434/v1
#   EMBEDDING_MODEL=nomic-embed-text
#   EMBEDDING_VECTOR_SIZE=768
export EMBEDDING_API_KEY=
export EMBEDDING_BASE_URL=
export EMBEDDING_MODEL=gemini-embedding-001
export EMBEDDING_VECTOR_SIZE=3072

# Auth — set to a strong random string to protect the dashboard on public deployments
# If empty, auth is disabled (safe for local dev)
export APP_SECRET_KEY=

export APP_BASE=          # Public base URL, e.g. https://xyz.ngrok-free.dev
export USER_NAME=         # Your name — used in call prompts
export DATABASE_URL=      # SQLite path (default: contacts.db); set to /data/contacts.db for Docker
